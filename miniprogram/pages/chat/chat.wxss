.chat-container { display: flex; flex-direction: column; height: 100vh; background: #f8f9fa; }
.chat-list { flex: 1; padding: 32rpx; box-sizing: border-box; }
.chat-msg { display: flex; margin-bottom: 32rpx; align-items: flex-start; }
.chat-msg.user { flex-direction: row-reverse; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 40rpx; background: #fff; padding: 10rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.chat-msg.user .avatar { margin-left: 24rpx; background: #fff; }
.chat-msg.assistant .avatar { margin-right: 24rpx; background: #fff; }
.bubble { max-width: 65%; padding: 24rpx 32rpx; border-radius: 32rpx; font-size: 30rpx; line-height: 1.6; word-break: break-all; }
.chat-msg.assistant .bubble { background: #fff; color: var(--text-main); border-top-left-radius: 8rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03); }
.chat-msg.user .bubble { background: var(--primary); color: #fff; border-top-right-radius: 8rpx; }

.typing .dot { display: inline-block; width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--text-sub); margin: 0 6rpx; animation: bounce 1.4s infinite ease-in-out both; }
.typing .dot:nth-child(1) { animation-delay: -0.32s; }
.typing .dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }

.input-bar { display: flex; padding: 24rpx 32rpx; padding-bottom: env(safe-area-inset-bottom); background: #fff; align-items: center; }
.styled-input { flex: 1; background: #f1f5f9; padding: 20rpx 32rpx; border-radius: 40rpx; font-size: 28rpx; margin-right: 24rpx; }
.send-btn { padding: 0 40rpx; height: 76rpx; line-height: 76rpx; border-radius: 40rpx; font-size: 28rpx; margin: 0; }
.send-btn.disabled { opacity: 0.5; }
