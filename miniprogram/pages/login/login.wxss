.container { padding: 80rpx 48rpx; height: 100vh; background: #fff; box-sizing: border-box; }
.header-section { margin-bottom: 100rpx; }
.logo-placeholder { width: 180rpx; height: 180rpx; margin-bottom: 48rpx; }
.title { font-size: 64rpx; color: var(--text-main); display: block; margin-bottom: 20rpx; line-height: 1.2; }
.subtitle { font-size: 32rpx; color: var(--text-sub); }

.form-wrapper { width: 100%; }
.input-label { display: block; font-size: 28rpx; color: var(--text-main); margin-bottom: 16rpx; }
.styled-input { width: 100%; height: 100rpx; background: var(--surface); border: 2rpx solid var(--border); border-radius: 24rpx; padding: 0 32rpx; font-size: 32rpx; color: var(--text-main); box-sizing: border-box; transition: all 0.2s; }
.styled-input:focus { border-color: var(--text-main); background: #fff; }
.ph-color { color: #a1a1aa; }

.login-btn { width: 100% !important; height: 110rpx; background: var(--text-main) !important; color: #fff !important; border-radius: 55rpx; display: flex; align-items: center; justify-content: center; font-size: 34rpx; margin-top: 80rpx; }
.login-btn[disabled] { opacity: 0.5; background: var(--text-main) !important; color: #fff !important;}
.login-btn:active { opacity: 0.8; }
.toggle-text {
  font-size: 28rpx;
  color: var(--primary);
  text-align: center;
  margin-top: 40rpx;
  padding: 20rpx;
  cursor: pointer;
}
