.container { padding: 40rpx; min-height: 100vh; background: #fafafa; }
.header { margin-bottom: 40rpx; }
.title { font-size: 56rpx; color: var(--text-main); }

.list { padding-bottom: 60rpx; }
.notification-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-subtle);
  position: relative;
  transition: all 0.2s ease;
}
.notification-card.read {
  opacity: 0.6;
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.badge {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--danger);
  position: absolute;
  top: 46rpx;
  left: 16rpx;
}
.card-title {
  font-size: 32rpx;
  color: var(--text-main);
  flex: 1;
  margin-left: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.notification-card:not(.read) .card-title {
  padding-left: 12rpx;
}
.card-time {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-left: 20rpx;
}
.card-desc {
  font-size: 28rpx;
  color: var(--text-sub);
  line-height: 1.5;
  display: block;
}
.empty-state, .loading-state {
  text-align: center;
  color: var(--text-sub);
  margin-top: 100rpx;
  font-size: 28rpx;
}
