.container { padding: 40rpx 48rpx 100rpx; background: #fff; box-sizing: border-box; min-height: 100vh; }
.header-section { margin-bottom: 60rpx; }
.title { font-size: 56rpx; color: var(--text-main); display: block; margin-bottom: 16rpx; line-height: 1.2; }
.subtitle { font-size: 30rpx; color: var(--text-sub); }

.section-title { font-size: 36rpx; font-weight: bold; color: var(--text-main); margin: 60rpx 0 30rpx; border-left: 8rpx solid var(--primary); padding-left: 16rpx; }
.form-wrapper { width: 100%; }
.input-group { margin-bottom: 30rpx; }
.row-group { display: flex; align-items: center; margin-bottom: 30rpx; width: 100%; box-sizing: border-box;}
.flex-1 { flex: 1; }
.space { width: 24rpx; }

.styled-input { width: 100%; height: 96rpx; background: var(--surface); border: 2rpx solid var(--border); border-radius: 20rpx; padding: 0 32rpx; font-size: 30rpx; color: var(--text-main); box-sizing: border-box; transition: all 0.2s; }
.picker-text { display: flex; align-items: center; }
.styled-input:focus { border-color: var(--text-main); background: #fff; }
.ph-color { color: #a1a1aa; }

.login-btn { width: 100% !important; height: 104rpx; background: var(--text-main) !important; color: #fff !important; border-radius: 52rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; margin-top: 80rpx; }
.login-btn[disabled] { opacity: 0.5; background: var(--text-main) !important; color: #fff !important;}
.login-btn:active { opacity: 0.8; }

.multi-select-group { display: flex; flex-wrap: wrap; gap: 20rpx; margin-bottom: 24rpx; }
.select-chip { display: inline-block; padding: 12rpx 32rpx; background: var(--surface); color: var(--text-sub); border-radius: 40rpx; font-size: 26rpx; border: 2rpx solid transparent; transition: all 0.2s; }
.chip-active { background: #fff; color: var(--primary); border: 2rpx solid var(--primary); font-weight: 600; }

.agreement-section {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-top: 30rpx;
  margin-bottom: 30rpx;
  font-size: 24rpx;
  color: #6b7280;
}
.agreement-section checkbox-group {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.agreement-label {
  display: flex;
  align-items: center;
}
.agreement-text {
  color: #6b7280;
}
.link-text {
  color: #3b82f6;
  display: inline;
}
