.container { padding: 40rpx 32rpx; padding-bottom: 100rpx; }
.profile-header { display: flex; align-items: center; margin-bottom: 60rpx; margin-top: 40rpx; }
.avatar-wrap { width: 140rpx; height: 140rpx; border-radius: 40rpx; background: var(--surface); border: 2rpx solid var(--border); display: flex; align-items: center; justify-content: center; margin-right: 32rpx; }
.avatar-img { width: 64rpx; height: 64rpx; opacity: 0.6; }
.user-meta { display: flex; flex-direction: column; justify-content: center; }
.user-name { font-size: 52rpx; color: var(--text-main); margin-bottom: 12rpx; display: block; }
.user-id { font-size: 28rpx; color: var(--text-sub); }

.stats-row { display: flex; background: #fff; padding: 40rpx 0; margin-bottom: 60rpx; }
.stat-block { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stat-val { font-size: 52rpx; color: var(--text-main); margin-bottom: 8rpx; font-family: DIN, sans-serif; }
.stat-lbl { font-size: 26rpx; color: var(--text-sub); font-weight: 500; }
.stat-line { width: 2rpx; background: var(--border); }

.menu-group { margin-bottom: 50rpx; }
.group-title { font-size: 32rpx; color: var(--text-main); display: block; margin-bottom: 24rpx; padding-left: 8rpx; }
.menu-card { background: #fff; overflow: hidden; }
.menu-item { display: flex; align-items: center; padding: 36rpx 32rpx; transition: background 0.2s; }
.menu-hover { background: var(--surface); }
.menu-icon-wrap { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; margin-right: 24rpx; }
.menu-icon { width: 44rpx; height: 44rpx; opacity: 0.7; }
.menu-text { flex: 1; font-size: 32rpx; color: var(--text-main); }
.menu-divider { height: 1rpx; background: var(--border); margin: 0 32rpx; }