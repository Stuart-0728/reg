.container { background: #fff; padding-bottom: 220rpx; min-height: 100vh; }
.cover-wrapper { width: 100%; height: 600rpx; background: var(--surface); }
.cover-image { width: 100%; height: 100%; }

.content { padding: 48rpx 32rpx; }
.header-section { margin-bottom: 40rpx; }
.tag-row { display: flex; gap: 16rpx; margin-bottom: 32rpx; }
.type-tag, .points-tag { font-size: 24rpx; font-weight: 600; padding: 10rpx 24rpx; border-radius: 12rpx; }
.type-tag { background: var(--text-main); color: #fff; }
.points-tag { background: var(--surface); color: var(--text-main); border: 1rpx solid var(--border); }
.title { font-size: 52rpx; color: var(--text-main); line-height: 1.3; display: block; }

.divider { height: 1rpx; background: var(--border); margin: 0 0 40rpx 0; }

.info-list { display: flex; flex-direction: column; gap: 40rpx; margin-bottom: 40rpx; }
.info-row { display: flex; align-items: flex-start; }
.icon-box { width: 80rpx; height: 80rpx; background: var(--surface); border-radius: 20rpx; display: flex; align-items: center; justify-content: center; margin-right: 32rpx; border: 1rpx solid var(--border); }
.icon-img { width: 44rpx; height: 44rpx; opacity: 0.8; }
.info-text { flex: 1; display: flex; flex-direction: column; justify-content: center; height: 80rpx; }
.info-label { font-size: 24rpx; color: var(--text-sub); margin-bottom: 4rpx; }
.info-value { font-size: 30rpx; color: var(--text-main); }

.detail-section { margin-top: 20rpx; }
.section-title { font-size: 36rpx; color: var(--text-main); display: block; margin-bottom: 24rpx; }
.desc-text { font-size: 32rpx; color: var(--text-sub); line-height: 1.8; }

.action-bar { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.9); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); height: 180rpx; display: flex; align-items: center; padding: 0 32rpx; padding-bottom: env(safe-area-inset-bottom); z-index: 100; border-top-left-radius: 40rpx; border-top-right-radius: 40rpx;}
.icon-btn { background: transparent; padding: 0; margin: 0; width: 120rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; line-height: 1.2; box-shadow: none; outline: none; }
.icon-btn::after { display: none; }
.action-icon { width: 50rpx; height: 50rpx; margin-bottom: 10rpx; opacity: 0.8; }
.action-label { font-size: 22rpx; color: var(--text-sub); font-weight: 500; }
.btn-wrap { flex: 1; margin-left: 20rpx; }
.main-btn { background: var(--text-main); color: #fff; height: 100rpx; border-radius: 50rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.main-btn:active { opacity: 0.8; }.copy-link-btn { font-size: 24rpx; color: var(--primary); background: rgba(var(--primary-rgb), 0.1); padding: 12rpx 24rpx; border-radius: 30rpx; border: 1rpx solid rgba(var(--primary-rgb), 0.2); }

.btn-disabled { background: #E2E8F0; color: #94A3B8; }
.btn-special { background: #10B981; color: #FFF; }
.btn-danger { background: #EF4444; color: #FFF; }
