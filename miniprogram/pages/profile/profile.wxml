<view class="container">
  <view class="header-section" style="margin-bottom: 40rpx;">
    <text class="title font-heavy">个人档案</text>
    <text class="subtitle">完善或修改您的基本信息</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">正在加载...</view>

  <view class="form-wrapper" wx:else>
    <view class="section-title">基础档案 (请在网页版修改)</view>
    <view class="input-group">
      <text class="input-label">系统账号</text>
      <input class="styled-input disabled" value="{{form.username}}" disabled="true" />
    </view>
    <view class="input-group">
      <text class="input-label">学号/工号</text>
      <input class="styled-input disabled" value="{{form.student_id}}" disabled="true" />
    </view>
    <view class="input-group">
      <text class="input-label">加入的社团</text>
      <input class="styled-input disabled" value="{{form.society_name}}" disabled="true" />
    </view>

    <view class="section-title">信息修改</view>
    <view class="input-group">
      <text class="input-label">真实姓名</text>
      <input class="styled-input" model:value="{{form.real_name}}" />
    </view>
    <view class="input-group">
      <text class="input-label">常用电子邮箱</text>
      <input class="styled-input" type="text" model:value="{{form.email}}" />
    </view>
    
    <view class="row-group">
      <view class="flex-1">
        <text class="input-label">年级</text>
        <picker bindchange="onGradeChange" value="{{gradeIndex}}" range="{{grades}}">
          <view class="styled-input picker-text">{{form.grade}}</view>
        </picker>
      </view>
      <view class="space"></view>
      <view class="flex-1">
        <text class="input-label">所在学院</text>
        <input class="styled-input" model:value="{{form.college}}" />
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">所学专业</text>
      <input class="styled-input" model:value="{{form.major}}" />
    </view>

    <view class="input-group">
      <text class="input-label">手机号</text>
      <input class="styled-input" type="number" model:value="{{form.phone}}" />
    </view>
    <view class="input-group">
      <text class="input-label">QQ号</text>
      <input class="styled-input" type="number" model:value="{{form.qq}}" />
    </view>

    <button class="login-btn font-bold" bindtap="handleSave" loading="{{isSubmitting}}" disabled="{{isSubmitting}}">
      保存修改
    </button>
  </view>
</view>
