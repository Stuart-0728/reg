.container { padding: 40rpx 32rpx; padding-bottom: 80rpx; }
.header { margin-bottom: 60rpx; }
.title { font-size: 64rpx; color: var(--text-main); display: block; margin-bottom: 12rpx; }
.subtitle { font-size: 32rpx; color: var(--text-sub); }

.card { background: #fff; margin-bottom: 48rpx; overflow: hidden; }
.card-cover { position: relative; height: 320rpx; background: var(--surface); }
.cover-image { width: 100%; height: 100%; }

.backdrop-blur { background: rgba(255,255,255,0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
.badge { position: absolute; top: 32rpx; left: 32rpx; padding: 10rpx 28rpx; border-radius: 40rpx; border: 1rpx solid rgba(255,255,255,0.5); }
.badge-text { font-size: 24rpx; font-weight: 800; color: var(--text-main); }

.card-body { padding: 32rpx; }
.line-clamp-1 { display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
.card-title { font-size: 38rpx; color: var(--text-main); display: block; margin-bottom: 24rpx; line-height: 1.4; }

.card-meta { display: flex; justify-content: space-between; align-items: center; }
.meta-item { display: flex; align-items: center; }
.meta-icon { width: 32rpx; height: 32rpx; margin-right: 12rpx; opacity: 0.5; }
.meta-text { font-size: 26rpx; color: var(--text-sub); font-weight: 500; }

.meta-accent { background: var(--surface); padding: 12rpx 24rpx; border-radius: 20rpx; }
.meta-icon-accent { width: 28rpx; height: 28rpx; margin-right: 10rpx; opacity: 0.7; }
.meta-text-accent { font-size: 24rpx; color: var(--text-main); font-weight: 600; }

.loading-wrapper { display: flex; flex-direction: column; gap: 40rpx; }
.skeleton-box { width: 100%; height: 500rpx; background: var(--surface); border-radius: 32rpx; animation: pulse 2s infinite ease-in-out; }
@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }

.empty-state { text-align: center; padding: 100rpx 0; display:flex; flex-direction:column; align-items:center; }
.empty-icon { width: 120rpx; height: 120rpx; opacity: 0.2; margin-bottom: 24rpx;}
.empty-text { font-size: 28rpx; color: var(--text-muted); margin-bottom: 40rpx;}
.ghost-btn { background: transparent; border: 2rpx solid var(--border); color: var(--text-main); border-radius: 40rpx; font-size: 28rpx; padding: 0 40rpx; }
.meta-cancel { padding: 12rpx 24rpx; border-radius: 20rpx; border: 2rpx solid #ef4444; color: #ef4444; font-size: 24rpx; font-weight: 600; margin-left: auto; }

.filter-tabs { display: flex; align-items: center; justify-content: space-around; background: #fff; padding: 24rpx 0; border-radius: 24rpx; margin-bottom: 40rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); }
.filter-tab { font-size: 28rpx; color: var(--text-sub); padding: 12rpx 32rpx; border-radius: 32rpx; font-weight: 500; transition: all 0.3s ease; }
.filter-tab.active { background: var(--primary); color: #fff; box-shadow: 0 4rpx 12rpx rgba(var(--primary-rgb), 0.3); }

.action-buttons { display: flex; gap: 16rpx; margin-left: auto; }
.action-btn { padding: 12rpx 24rpx; border-radius: 20rpx; font-size: 24rpx; font-weight: 600; }
.meta-register { border: 2rpx solid var(--primary); color: var(--primary); }
